<%- include('../partials/head') %>
</head>

<body>
    <%- include('../partials/nav') %>

    <main style="max-width: 900px; margin: 40px auto; padding: 0 16px;">
        <h2 style="font-size: 22px; font-weight: 700; color: #e03131; text-align: center; margin-bottom: 24px;">
            Here are our registered homes:
        </h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px;">
            <% registeredHomes.forEach((home, index)=>{ %>
                <div style="background: white; border: 1px solid #ddd; border-radius: 12px; overflow: hidden;">
                   <img src="<%= home.photo %>" alt="<%= home.houseName %>" 
                    style="width: 100%; height: 180px; object-fit: cover;" />
                    <div style="padding: 16px;">
                        <h3 style="font-size: 16px; font-weight: 700; color: #222; margin-bottom: 6px;">
                            <%= home.houseName %>
                        </h3>
                        <p style="font-size: 13px; color: #777; margin-bottom: 10px;">
                            📍 <%= home.location %>
                        </p>
                        <p style="font-size: 15px; font-weight: 700; color: #e03131; margin-bottom: 16px;">
                            ₹<%= home.price %> / night
                        </p>
                        <div style="display: flex; gap: 8px; align-items: stretch;">
                            <a href="/homes/<%= home._id %>" 
                                style="flex: 1; display: flex; align-items: center; justify-content: center; padding: 10px; background: white; color: #e03131; border: 1.5px solid #e03131; text-decoration: none; border-radius: 8px; font-size: 13px; font-weight: 600;">
                                🔍 Details
                            </a>
                            <form action="/favourites" method="POST" style="flex: 1; margin: 0;">

    <input type="hidden" name="Id" value="<%= home._id %>">

    <button type="submit"
        style="width: 100%; height: 100%; padding: 10px; background: #fff5f5; color: #e03131; border: 1.5px solid #e03131; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer;">
        ♡ Favourite
    </button>

</form>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </main>
</body>
</html>