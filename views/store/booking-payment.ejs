<%- include('../partials/head') %>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'Segoe UI', sans-serif; background: #f5f5f5; min-height: 100vh; }

  .wrapper { max-width: 520px; margin: 48px auto; padding: 0 20px; }

  .card {
    background: white;
    border-radius: 16px;
    padding: 36px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.09);
  }

  .home-preview {
    display: flex;
    gap: 14px;
    align-items: center;
    margin-bottom: 28px;
    padding-bottom: 20px;
    border-bottom: 1px solid #f0f0f0;
  }

  .home-preview img {
    width: 80px;
    height: 70px;
    object-fit: cover;
    border-radius: 10px;
  }

  .home-preview h3 { font-size: 16px; font-weight: 700; color: #1a1a1a; margin-bottom: 4px; }
  .home-preview p { font-size: 13px; color: #888; }
  .home-preview .price { font-size: 15px; font-weight: 700; color: #e03131; }

  h2 { font-size: 20px; font-weight: 700; color: #1a1a1a; margin-bottom: 20px; }

  .form-group { margin-bottom: 18px; }
  .form-group label { display: block; font-size: 13px; font-weight: 600; color: #444; margin-bottom: 8px; }
  .form-group input {
    width: 100%;
    padding: 11px 14px;
    border: 1.5px solid #e0e0e0;
    border-radius: 8px;
    font-size: 14px;
    outline: none;
    transition: border 0.2s;
  }
  .form-group input:focus { border-color: #e03131; }

  .total-box {
    background: #fff0f0;
    border: 1.5px solid #e03131;
    border-radius: 10px;
    padding: 14px 18px;
    margin: 20px 0 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .total-box span { font-size: 14px; color: #666; }
  .total-box strong { font-size: 18px; font-weight: 800; color: #e03131; }

  .error { color: #e03131; font-size: 13px; margin-bottom: 14px; }

  .submit-btn {
    width: 100%;
    padding: 13px;
    background: #e03131;
    color: white;
    font-size: 15px;
    font-weight: 600;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.2s;
  }
  .submit-btn:hover { background: #c92a2a; }
</style>
</head>
<body>
<%- include('../partials/nav') %>

<div class="wrapper">
  <div class="card">

    <div class="home-preview">
      <img src="<%= home.photo %>" alt="<%= home.houseName %>" />
      <div>
        <h3><%= home.houseName %></h3>
        <p>📍 <%= home.location %></p>
        <p class="price">₹<%= home.price %> / night</p>
      </div>
    </div>

    <h2>Select Your Dates</h2>

    <% if(errorMessages.length > 0) { %>
      <% errorMessages.forEach(msg => { %>
        <p class="error">⚠️ <%= msg %></p>
      <% }) %>
    <% } %>

    <form action="/book/<%= home._id %>" method="POST" id="bookingForm">
      <div class="form-group">
        <label>Check-In Date</label>
        <input type="date" name="checkIn" required min="<%= new Date().toISOString().split('T')[0] %>" />
      </div>

      <div class="form-group">
        <label>Check-Out Date</label>
        <input type="date" name="checkOut" required min="<%= new Date().toISOString().split('T')[0] %>" />
      </div>

      <div class="total-box">
        <span>Estimated Total</span>
        <strong id="totalPrice">Select dates</strong>
      </div>

      <button type="submit" class="submit-btn">Proceed to Payment →</button>
    </form>
  </div>
</div>

<script>
  const pricePerNight = <%= home.price %>;
  const checkIn = document.querySelector('[name="checkIn"]');
  const checkOut = document.querySelector('[name="checkOut"]');
  const totalEl = document.getElementById('totalPrice');

  function calcTotal() {
    if (checkIn.value && checkOut.value) {
      const nights = Math.ceil((new Date(checkOut.value) - new Date(checkIn.value)) / (1000 * 60 * 60 * 24));
      if (nights > 0) {
        totalEl.textContent = '₹' + (nights * pricePerNight).toLocaleString('en-IN');
      } else {
        totalEl.textContent = 'Invalid dates';
      }
    }
  }

  checkIn.addEventListener('change', calcTotal);
  checkOut.addEventListener('change', calcTotal);
</script>

</body>
</html>