<%- include('../partials/head') %>
</head>

<body style="background: #f7f7f7; font-family: 'Georgia', serif; margin: 0;">

    <%- include('../partials/nav') %>

    <main style="max-width: 760px; margin: 48px auto; padding: 0 20px;">

        <!-- Image with overlay badge -->
        <div style="position: relative; border-radius: 20px; overflow: hidden; box-shadow: 0 8px 32px rgba(0,0,0,0.13);">
           <img src="<%= home.photo %>" alt="<%= home.houseName %>"
                style="width: 100%; height: 340px; object-fit: cover; display: block;" />
            <div style="position: absolute; bottom: 16px; left: 20px; background: rgba(255,255,255,0.92); backdrop-filter: blur(6px); border-radius: 10px; padding: 10px 18px;">
                <p style="margin: 0; font-size: 13px; color: #888;">📍 <%= home.location %></p>
            </div>
        </div>

        <!-- Content Card -->
        <div style="background: white; border-radius: 20px; padding: 36px 40px; margin-top: 24px; box-shadow: 0 2px 16px rgba(0,0,0,0.07);">

            <!-- Title + Price Row -->
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px; flex-wrap: wrap; gap: 10px;">
                <h1 style="font-size: 26px; font-weight: 700; color: #1a1a1a; margin: 0; line-height: 1.2;">
                    <%= home.houseName %>
                </h1>
                <div style="background: #fff0f0; border: 1.5px solid #e03131; border-radius: 10px; padding: 8px 18px; text-align: center;">
                    <p style="margin: 0; font-size: 20px; font-weight: 800; color: #e03131;">₹<%= home.price %></p>
                    <p style="margin: 0; font-size: 11px; color: #aaa; letter-spacing: 0.5px;">per night</p>
                </div>
            </div>

            <!-- Divider -->
            <hr style="border: none; border-top: 1px solid #f0f0f0; margin-bottom: 20px;" />

            <!-- Description -->
            <p style="font-size: 13px; font-weight: 700; color: #bbb; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px;">About this place</p>
            <p style="font-size: 15px; color: #555; line-height: 1.8; margin-bottom: 32px;"><%= home.description %></p>

            <div style="
    background:#fafafa;
    border:1px solid #eee;
    border-radius:16px;
    padding:20px;
    margin-bottom:30px;
">

    <p style="
        font-size:13px;
        font-weight:700;
        color:#bbb;
        text-transform:uppercase;
        letter-spacing:1px;
        margin-bottom:16px;
    ">
        Host Information
    </p>

    <div style="
        display:flex;
        align-items:center;
        gap:14px;
        margin-bottom:14px;
    ">

        <div style="
            width:48px;
            height:48px;
            border-radius:50%;
            background:#e03131;
            color:white;
            display:flex;
            align-items:center;
            justify-content:center;
            font-size:18px;
            font-weight:700;
        ">
            <%= home.userId.firstName ? home.userId.firstName.charAt(0).toUpperCase() : '?' %>
        </div>

        <div>
            <div style="font-size:16px;font-weight:700;color:#222;">
                <%= home.userId.firstName %> <%= home.userId.lastName || '' %>
            </div>

            <div style="font-size:13px;color:#888;">
                Property Host
            </div>
        </div>

    </div>

    <p style="margin:8px 0;color:#555;">
        📧 <%= home.userId.email %>
    </p>

    <p style="margin:8px 0;color:#555;">
        📞 XXX-XXX-XXXX
    </p>

</div>

            <!-- Action Buttons -->
            <div style="display: flex; gap: 12px; flex-wrap: wrap;">

                <% if (user && home.userId.toString() === user._id.toString()) { %>

    <div
        style="
            flex:1;
            min-width:140px;
            padding:14px;
            background:#e7f5ff;
            color:#1864ab;
            border:1px solid #a5d8ff;
            border-radius:10px;
            text-align:center;
            font-size:14px;
            font-weight:700;
        ">
        🏠 You are the host of this property
    </div>

<% } else { %>

    <a href="/book/<%= home.id %>"
        style="flex: 1; min-width: 140px; display: block; text-align: center; padding: 14px; background: #e03131; color: white; text-decoration: none; border-radius: 10px; font-size: 14px; font-weight: 700; letter-spacing: 0.3px; box-shadow: 0 4px 14px rgba(224,49,49,0.3); transition: opacity 0.2s;"
        onmouseover="this.style.opacity='0.88'"
        onmouseout="this.style.opacity='1'">
        🏠 Book Now
    </a>

<% } %>

                <a href="/home-rules" download="home_rules.pdf"
                    style="flex: 1; min-width: 140px; display: block; text-align: center; padding: 14px; background: white; color: #e03131; border: 2px solid #e03131; text-decoration: none; border-radius: 10px; font-size: 14px; font-weight: 700; transition: background 0.2s, color 0.2s;"
                    onmouseover="this.style.background='#fff0f0'" onmouseout="this.style.background='white'">
                    📄 House Rules
                </a>

                <%- include('../partials/favourite') %>

            </div>
        </div>
    </main>

</body>
</html>