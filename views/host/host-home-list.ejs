<%- include('../partials/head') %>
</head>

<body>
    <%- include('../partials/nav') %>

    <main style="max-width: 900px; margin: 40px auto; padding: 0 16px;">

        <h2 style="font-size: 22px; font-weight: 700; color: #e03131; text-align: center; margin-bottom: 24px;">
            Hey Host here are your homes:
        </h2>

        <% if(typeof errorMessage !== 'undefined' && errorMessage) { %>
          <div style="background: #fff0f0; border: 1.5px solid #e03131; color: #e03131; padding: 12px 18px; border-radius: 8px; margin-bottom: 20px; font-size: 14px; font-weight: 600; text-align: center;">
            ⚠️ <%= errorMessage %>
          </div>
        <% } %>

        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px;">
            <% registeredHomes.forEach((home, index)=>{ %>
                <div style="background: white; border: 1px solid #ddd; border-radius: 12px; overflow: hidden;">
                    <img src="/<%= home.photo.replace(/\\/g, '/') %>" alt="<%= home.houseName %>" 
                        style="width: 100%; height: 180px; object-fit: cover;" />
                    <div style="padding: 16px;">
                        <h3 style="font-size: 16px; font-weight: 700; color: #222; margin-bottom: 6px;">
                            <%= home.houseName %>
                        </h3>
                        <p style="font-size: 13px; color: #777; margin-bottom: 10px;">
                            📍 <%= home.location %>
                        </p>
                        <p style="font-size: 15px; font-weight: 700; color: #e03131; margin-bottom: 16px;">
                            ₹<%= home.price %> / night
                        </p>
                        <div style="display: flex; gap: 8px;">
                            <a href="/host/edit-home/<%= home._id %>?editing=true" 
                                style="flex: 1; display: block; text-align: center; padding: 10px; background: #e03131; color: white; text-decoration: none; border-radius: 8px; font-size: 14px; font-weight: 500;">
                                Edit
                            </a>
                            <form action="/host/delete-home/<%= home._id %>" method="POST" style="flex: 1;">
                                <input type="hidden" name="index" value="<%= index %>" />
                                <button type="submit" 
                                    style="width: 100%; padding: 10px; background: white; color: #e03131; border: 1.5px solid #e03131; border-radius: 8px; font-size: 14px; font-weight: 500; cursor: pointer;">
                                    Delete
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </main>
</body>
</html>