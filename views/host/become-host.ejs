<%- include('../partials/head') %>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Segoe UI', sans-serif;
    background: #f5f5f5;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .wrapper {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 16px;
  }

  .card {
    background: white;
    border-radius: 16px;
    padding: 48px 36px;
    width: 100%;
    max-width: 480px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.1);
    text-align: center;
  }

  .icon {
    font-size: 56px;
    margin-bottom: 20px;
  }

  h2 {
    font-size: 24px;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 10px;
  }

  p {
    font-size: 15px;
    color: #666;
    margin-bottom: 32px;
    line-height: 1.6;
  }

  .perks {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 36px;
    text-align: left;
  }

  .perk {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 14px;
    color: #444;
  }

  .perk span.emoji {
    font-size: 20px;
  }

  .btn-become {
    width: 100%;
    padding: 14px;
    background: #e03131;
    color: white;
    font-size: 16px;
    font-weight: 600;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.2s;
    margin-bottom: 12px;
  }

  .btn-become:hover { background: #c92a2a; }

  .btn-cancel {
    width: 100%;
    padding: 13px;
    background: white;
    color: #444;
    font-size: 15px;
    font-weight: 500;
    border: 1.5px solid #e0e0e0;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
    display: block;
  }

  .btn-cancel:hover {
    background: #f5f5f5;
    border-color: #ccc;
  }
</style>
</head>
<body>

<%- include('../partials/nav') %>

<div class="wrapper">
  <div class="card">

    <div class="icon">🏠</div>
    <h2>Become a Host</h2>
    <p>You're currently a Guest. To list your property, you need to switch to a Host account.</p>

    <div class="perks">
      <div class="perk">
        <span class="emoji">💰</span>
        <span>Earn money by renting out your space</span>
      </div>
      <div class="perk">
        <span class="emoji">📋</span>
        <span>List and manage multiple properties</span>
      </div>
      <div class="perk">
        <span class="emoji">✏️</span>
        <span>Edit or remove your listings anytime</span>
      </div>
    </div>

    <form action="/host/become-host" method="POST">
      <button type="submit" class="btn-become">Become a Host</button>
    </form>

    <a href="/" class="btn-cancel">Maybe Later</a>

  </div>
</div>

</body>
</html>