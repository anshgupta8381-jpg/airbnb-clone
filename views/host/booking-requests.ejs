<%- include('../partials/head') %>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'Segoe UI', sans-serif; background: #f5f5f5; min-height: 100vh; }

  .wrapper { max-width: 850px; margin: 48px auto; padding: 0 20px; }

  h1 { font-size: 24px; font-weight: 700; color: #1a1a1a; margin-bottom: 24px; }

  .empty {
    background: white;
    border-radius: 16px;
    padding: 60px 36px;
    text-align: center;
    box-shadow: 0 2px 16px rgba(0,0,0,0.07);
  }
  .empty .icon { font-size: 52px; margin-bottom: 16px; }
  .empty h3 { font-size: 18px; font-weight: 600; color: #1a1a1a; margin-bottom: 8px; }
  .empty p { font-size: 14px; color: #888; }

  .request-card {
    background: white;
    border-radius: 16px;
    padding: 24px;
    margin-bottom: 18px;
    box-shadow: 0 2px 16px rgba(0,0,0,0.07);
    display: flex;
    gap: 20px;
    align-items: center;
  }

  .request-card img {
    width: 110px;
    height: 90px;
    object-fit: cover;
    border-radius: 12px;
    flex-shrink: 0;
  }

  .request-info { flex: 1; }
  .request-info h3 { font-size: 16px; font-weight: 700; color: #1a1a1a; margin-bottom: 6px; }
  .request-info p { font-size: 13px; color: #777; margin-bottom: 4px; }
  .request-info .guest { font-size: 13px; color: #444; font-weight: 600; margin-bottom: 4px; }

  .request-right { text-align: right; flex-shrink: 0; }
  .request-right .price { font-size: 20px; font-weight: 800; color: #e03131; margin-bottom: 8px; }

  .badge {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    margin-bottom: 10px;
  }
  .badge.confirmed { background: #d3f9d8; color: #2f9e44; }
  .badge.pending { background: #fff3bf; color: #e67700; }
  .badge.rejected { background: #ffe3e3; color: #e03131; }

  .action-btns { display: flex; gap: 8px; justify-content: flex-end; }

  .accept-btn {
    padding: 7px 16px;
    background: #2f9e44;
    color: white;
    border: none;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
  }
  .accept-btn:hover { background: #276535; }

  .reject-btn {
    padding: 7px 16px;
    background: white;
    color: #e03131;
    border: 1.5px solid #e03131;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }
  .reject-btn:hover { background: #fff0f0; }
</style>
</head>
<body>

<%- include('../partials/nav') %>

<div class="wrapper">
  <h1>Booking Requests</h1>

  <% if(requests.length === 0) { %>
    <div class="empty">
      <div class="icon">📋</div>
      <h3>No booking requests yet</h3>
      <p>When guests book your homes, requests will appear here.</p>
    </div>

  <% } else { %>
    <% requests.forEach(request => { %>
      <div class="request-card">

        <img src="<%= request.homeId?.photo || '/images/fallback.jpg' %>" alt="<%= request.homeId.houseName %>" />

        <div class="request-info">
          <h3><%= request.homeId.houseName %></h3>
          <p class="guest">👤 Guest: <%= request.userId.firstName %> <%= request.userId.lastName || '' %></p>
          <p>📧 <%= request.userId.email %></p>
          <p>📅 Check-In: <strong><%= new Date(request.checkIn).toDateString() %></strong></p>
          <p>📅 Check-Out: <strong><%= new Date(request.checkOut).toDateString() %></strong></p>
        </div>

        <div class="request-right">
          <p class="price">₹<%= request.totalPrice.toLocaleString('en-IN') %></p>

          <span class="badge <%= request.status %>">
            <% if(request.status === 'confirmed') { %> ✅ Confirmed
            <% } else if(request.status === 'rejected') { %> ❌ Rejected
            <% } else { %> ⏳ Pending
            <% } %>
          </span>

          <% if(request.status === 'pending') { %>
            <div class="action-btns">
              <form action="/booking/accept/<%= request._id %>" method="POST">
                <button type="submit" class="accept-btn">✅ Accept</button>
              </form>
              <form action="/booking/reject/<%= request._id %>" method="POST">
                <button type="submit" class="reject-btn">❌ Reject</button>
              </form>
            </div>

          <% } else if(request.status === 'confirmed') { %>
            <div class="action-btns">
              <form action="/booking/reject/<%= request._id %>" method="POST">
                <button type="submit" class="reject-btn">❌ Cancel Booking</button>
              </form>
            </div>

          <% } %>
        </div>

      </div>
    <% }) %>
  <% } %>

</div>

</body>
</html>