<%- include('../partials/head') %>

<style>
  *{
    margin:0;
    padding:0;
    box-sizing:border-box;
  }

  body{
    font-family:Segoe UI,sans-serif;
    background:#f5f5f5;
  }

  .container{
    max-width:1200px;
    margin:40px auto;
    padding:0 20px;
  }

  .title{
    font-size:32px;
    font-weight:700;
    margin-bottom:25px;
    color:#222;
  }

  .stats-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
    gap:20px;
    margin-bottom:40px;
  }

  .card{
    background:white;
    padding:25px;
    border-radius:16px;
    box-shadow:0 2px 12px rgba(0,0,0,0.08);
  }

  .card h3{
    color:#777;
    font-size:14px;
    margin-bottom:10px;
  }

  .card .number{
    font-size:32px;
    font-weight:700;
    color:#111;
  }

  .earnings{
    color:#16a34a;
  }

  .pending{
    color:#f59e0b;
  }

  .confirmed{
    color:#10b981;
  }

  .rejected{
    color:#ef4444;
  }

  .section-title{
    font-size:24px;
    font-weight:700;
    margin-bottom:20px;
    color:#222;
  }

  .table-wrapper{
    background:white;
    border-radius:16px;
    overflow:hidden;
    box-shadow:0 2px 12px rgba(0,0,0,0.08);
  }

  table{
    width:100%;
    border-collapse:collapse;
  }

  th{
    background:#f8f9fa;
    padding:16px;
    text-align:left;
    font-size:14px;
  }

  td{
    padding:16px;
    border-top:1px solid #eee;
    font-size:14px;
  }

  .status{
    padding:6px 12px;
    border-radius:20px;
    font-size:12px;
    font-weight:600;
  }

  .status.pending{
    background:#fff3cd;
    color:#856404;
  }

  .status.confirmed{
    background:#d1fae5;
    color:#065f46;
  }

  .status.rejected{
    background:#fee2e2;
    color:#991b1b;
  }

  .empty{
    background:white;
    padding:40px;
    border-radius:16px;
    text-align:center;
    box-shadow:0 2px 12px rgba(0,0,0,0.08);
  }
</style>

</head>

<body>

<%- include('../partials/nav') %>

<div class="container">

  <h1 class="title">Host Dashboard</h1>

  <div class="stats-grid">

    <div class="card">
      <h3>Total Homes</h3>
      <div class="number"><%= totalHomes %></div>
    </div>

    <div class="card">
      <h3>Pending Requests</h3>
      <div class="number pending"><%= pendingCount %></div>
    </div>

    <div class="card">
      <h3>Confirmed Bookings</h3>
      <div class="number confirmed"><%= confirmedCount %></div>
    </div>

    <div class="card">
      <h3>Rejected Bookings</h3>
      <div class="number rejected"><%= rejectedCount %></div>
    </div>

    <div class="card">
      <h3>Total Earnings</h3>
      <div class="number earnings">
        ₹<%= totalEarnings.toLocaleString('en-IN') %>
      </div>
    </div>

  </div>

  <h2 class="section-title">Recent Booking Requests</h2>

  <% if(recentBookings.length === 0){ %>

    <div class="empty">
      <h3>No bookings received yet</h3>
    </div>

  <% } else { %>

    <div class="table-wrapper">

      <table>

        <thead>
          <tr>
            <th>Guest</th>
            <th>Property</th>
            <th>Check In</th>
            <th>Check Out</th>
            <th>Amount</th>
            <th>Status</th>
          </tr>
        </thead>

        <tbody>

          <% recentBookings.forEach(booking => { %>

            <tr>

              <td>
                <%= booking.userId?.firstName || booking.userId?.name || 'Guest' %>
              </td>

              <td>
                <%= booking.homeId?.houseName || 'Deleted Home' %>
              </td>

              <td>
                <%= new Date(booking.checkIn).toLocaleDateString() %>
              </td>

              <td>
                <%= new Date(booking.checkOut).toLocaleDateString() %>
              </td>

              <td>
                ₹<%= booking.totalPrice.toLocaleString('en-IN') %>
              </td>

              <td>
                <span class="status <%= booking.status %>">
                  <%= booking.status.toUpperCase() %>
                </span>
              </td>

            </tr>

          <% }) %>

        </tbody>

      </table>

    </div>

  <% } %>

</div>

</body>
</html>