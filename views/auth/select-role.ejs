<%- include('../partials/head') %>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Segoe UI', sans-serif;
    background: #f5f5f5;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .wrapper {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 16px;
  }

  .card {
    background: white;
    border-radius: 16px;
    padding: 40px 36px;
    width: 100%;
    max-width: 480px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.1);
    text-align: center;
  }

  .logo {
    font-size: 28px;
    font-weight: 700;
    color: #e03131;
    margin-bottom: 24px;
  }

  h2 {
    font-size: 22px;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 8px;
  }

  p {
    font-size: 14px;
    color: #888;
    margin-bottom: 32px;
  }

  .roles {
    display: flex;
    gap: 16px;
    margin-bottom: 28px;
  }

  .role-card {
    flex: 1;
    border: 2px solid #e0e0e0;
    border-radius: 12px;
    padding: 24px 16px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .role-card:hover {
    border-color: #e03131;
    background: #fff5f5;
  }

  .role-card.selected {
    border-color: #e03131;
    background: #fff5f5;
  }

  .role-card .icon {
    font-size: 36px;
    margin-bottom: 12px;
  }

  .role-card h3 {
    font-size: 16px;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 6px;
  }

  .role-card p {
    font-size: 12px;
    color: #888;
    margin: 0;
  }

  .submit-btn {
    width: 100%;
    padding: 13px;
    background: #e03131;
    color: white;
    font-size: 15px;
    font-weight: 600;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.2s;
  }

  .submit-btn:hover { background: #c92a2a; }
</style>
</head>
<body>

<%- include('../partials/nav') %>

<div class="wrapper">
  <div class="card">
    <div class="logo">airbnb</div>
    <h2>How will you use Airbnb?</h2>
    <p>Choose your role to get started</p>

    <form action="/auth/select-role" method="POST">
      <div class="roles">

        <label class="role-card" id="guest-card">
          <input type="radio" name="userType" value="guest" hidden required />
          <div class="icon">🧳</div>
          <h3>Guest</h3>
          <p>Explore & book amazing places to stay</p>
        </label>

        <label class="role-card" id="host-card">
          <input type="radio" name="userType" value="host" hidden />
          <div class="icon">🏠</div>
          <h3>Host</h3>
          <p>List your property & earn money</p>
        </label>

      </div>

      <button type="submit" class="submit-btn">Continue</button>
    </form>
  </div>
</div>

<script>
  document.querySelectorAll('.role-card').forEach(card => {
    card.addEventListener('click', () => {
      document.querySelectorAll('.role-card').forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');
    });
  });
</script>

</body>
</html>